{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "1.0.0",
  "id": "${{BOT_ID}}",
  "developer": {
    "name": "Deop.ca",
    "websiteUrl": "https://github.com/hkaanturgut/deop-pm-agent",
    "privacyUrl": "https://github.com/hkaanturgut/deop-pm-agent",
    "termsOfUseUrl": "https://github.com/hkaanturgut/deop-pm-agent"
  },
  "name": {
    "short": "Deop PM Agent",
    "full": "Deop PM Agent — AI Project Management Assistant"
  },
  "description": {
    "short": "AI-powered project management assistant for Teams",
    "full": "Manage tasks, projects, and clients with natural language. Get daily standups, client reports, meeting prep, and smart reminders — all inside Microsoft Teams."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#4F6BED",
  "bots": [
    {
      "botId": "${{BOT_ID}}",
      "scopes": ["personal", "team", "groupChat"],
      "supportsFiles": false,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": ["personal"],
          "commands": [
            {"title": "standup", "description": "Get today's daily standup summary"},
            {"title": "tasks", "description": "List your tasks (filter by client/project)"},
            {"title": "overdue", "description": "Show overdue tasks"},
            {"title": "reminders", "description": "Get smart reminders and deadlines"},
            {"title": "report", "description": "Generate a client status report"},
            {"title": "meetings", "description": "Show upcoming meetings"},
            {"title": "prep", "description": "Get meeting preparation summary"},
            {"title": "new task", "description": "Create a new task"},
            {"title": "new project", "description": "Create a new project"},
            {"title": "new client", "description": "Register a new client"},
            {"title": "help", "description": "Show available commands"}
          ]
        }
      ]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["${{BOT_DOMAIN}}"]
}
